<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="StartUpBackground" Color="#FFEFF1FF"/>
    <SolidColorBrush x:Key="DefaulWindowBackground" Color="White"/>
    <SolidColorBrush x:Key="LittleDarkWindowBackground" Color="#FFEEEEF2"/>
    <SolidColorBrush x:Key="BlueDarkWindowBackground" Color="#FFD7E4F2"/>
    <SolidColorBrush x:Key="DarkBackground" Color="Black"/>
    <LinearGradientBrush x:Key="DefaulMenuBackground" EndPoint="0.5,1" StartPoint="0.5,0">
        <LinearGradientBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                <RotateTransform Angle="-78" CenterX="0.5" CenterY="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="#FFF0F0F0"/>
        <GradientStop Color="White" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DefaulToolbarBackground" Color="#FFEEF5FD"/>
    <SolidColorBrush x:Key="WorkingToolbarBackground" Color="#FFCA5100"/>
    <SolidColorBrush x:Key="DefaulBorder" Color="#FFA0A0A0"/>
    <SolidColorBrush x:Key="InputWordColor" Color="Blue"/>
    <SolidColorBrush x:Key="InsideBorder" Color="Black"/>
    <SolidColorBrush x:Key="HeaderColor" Color="#FFEEEEF2"/>
    <SolidColorBrush x:Key="PassColor" Color="#FF13B013"/>
    <SolidColorBrush x:Key="RunColor" Color="Red"/>
    <SolidColorBrush x:Key="ImportantColor" Color="Red"/>
    <SolidColorBrush x:Key="FunctionColor" Color="Blue"/>
    <SolidColorBrush x:Key="HelpAnnotationColor" Color="Blue"/>
    <SolidColorBrush x:Key="StartTipWordColor" Color="#FFA0A0A0"/>
    <Style TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="UndoLimit" Value="0"/>
        <Setter Property="IsUndoEnabled" Value="False"/>
    </Style>
    <Style TargetType="{x:Type RichTextBox}">
        <Setter Property="UndoLimit" Value="0"/>
        <Setter Property="IsUndoEnabled" Value="False"/>
    </Style>
</ResourceDictionary>
