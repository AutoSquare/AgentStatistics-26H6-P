<Window x:Class="AgentStatistics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AutoSquare - AgentStatistics" Icon="Resources/icons/logo.ico" Height="820" Width="1280" MinHeight="820" MinWidth="1280"
        Background="#F8FAFC">
    <Grid x:Name="DashboardHost">
        <wv2:WebView2 x:Name="DashboardWebView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>
        <wv2:WebView2 x:Name="CursorSyncWebView"
                      Width="1"
                      Height="1"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      IsHitTestVisible="False"/>
        <Grid x:Name="CursorLoginOverlay"
              Panel.ZIndex="10"
              Background="White"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Background="#F8FAFC" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,8,12,8">
                    <Button Content="取消" Padding="18,6" Margin="0,0,8,0" Click="CursorLoginCancelButton_Click"/>
                    <Button Content="完成登录" Padding="18,6" Click="CursorLoginDoneButton_Click"/>
                </StackPanel>
                <TextBlock Text="Cursor 官网登录 / 切换账号"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           FontSize="16"
                           FontWeight="SemiBold"/>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="32,24" VerticalAlignment="Center">
                <TextBlock Text="请使用系统浏览器完成 Cursor 官网登录"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <TextBlock TextWrapping="Wrap"
                           Foreground="#475569"
                           FontSize="14"
                           LineHeight="24"
                           Text="内嵌窗口无法稳定完成 Cursor SSO。点击下方按钮会在默认浏览器打开 spending 页面；登录成功后回到本窗口点击「完成登录」。若浏览器未弹出，请手动访问 cursor.com 并登录同一账号。"/>
                <Button x:Name="CursorLoginOpenBrowserButton"
                        Content="在浏览器中打开 Cursor 登录页"
                        Padding="20,10"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Left"
                        Click="CursorLoginOpenBrowserButton_Click"/>
            </StackPanel>
            <wv2:WebView2 x:Name="CursorLoginWebView" Grid.Row="1" Visibility="Visible"/>
        </Grid>
    </Grid>
</Window>
